APP_NAME=Calculus Tutor API
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/calc_tutor
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8080
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=25
OCR_PROVIDER=tesseract
OCR_LANGUAGE=eng
TESSERACT_CMD=
MAX_UPLOAD_SIZE_MB=5
KNOWLEDGE_DATASETS_DIR=
RAG_TOP_K=4
